# Shared team database (Neon Postgres). Get this from your Neon project's
# connection-details panel — use the pooled connection string (hostname has
# "-pooler" in it). Ask whoever set up the project for the real value; never
# commit the filled-in version (.env.local is gitignored).
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require
